      "source": [
        "# 変数varに好きな正の整数を代入してください\n",
        "var = 30\n",
        "\n",
        "if var  %3 == 0 and var  %5 == 0:\n",
        "    # 3と5の両方の倍数の場合\n",
        "    print(\"FizzBuzz\")\n",
        "elif var  %3 == 0:\n",
        "    # 3の倍数の場合\n",
        "    print(\"Fizz\")\n",
        "elif var  %5 == 0:\n",
        "    # 5の倍数の場合\n",
        "    print(\"Buzz\")\n",
        "else:\n",
        "    # どの条件にも当てはまらない場合\n",
        "    print(var)"
      ]
    }
  ]
